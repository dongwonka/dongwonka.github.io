---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((paper) => ({
    params: { slug: paper.slug },
    props: {
      paper: {
        ...paper.data,
        slug: paper.slug
      }
    }
  }));
}

const { paper } = Astro.props;
const base = import.meta.env.BASE_URL;
const paperImage = `${base}${paper.image.replace(/^\//, '')}`;
const paperUrl = typeof paper.paperUrl === 'string' ? paper.paperUrl.trim() : '';
const hasPaperUrl = paper.paperStatus !== 'comingSoon' && /^https?:\/\/\S+$/i.test(paperUrl);
const date = new Date(`${paper.acceptedDate}T00:00:00`);
const displayDate = date.toLocaleDateString('en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={`${paper.title} | Dong Wang`} description={paper.summary}>
  <a
    href={base}
    class="mb-8 inline-flex items-center rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:border-sky-300 hover:text-sky-700"
  >
    Back to Home
  </a>

  <article class="space-y-7">
    <header class="space-y-4 border-b border-slate-200 pb-7">
      <h1 class="max-w-4xl text-3xl font-semibold leading-tight text-slate-950 sm:text-4xl">
        {paper.title}
      </h1>

      <p class="text-base leading-7 text-slate-700">{paper.authors.join(', ')}</p>

      <div class="flex flex-wrap gap-2">
        {paper.fieldTags.map((tag) => <Tag label={tag} type="field" />)}
        {paper.levelTags.map((tag) => <Tag label={tag} type="level" />)}
      </div>
    </header>

    <section class="grid gap-5 rounded-md border border-slate-200 bg-white p-5 shadow-sm sm:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Accepted By</p>
        <p class="mt-1 text-sm font-medium text-slate-900">{paper.venue}</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Accepted Date</p>
        <p class="mt-1 text-sm font-medium text-slate-900">{displayDate}</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Venue Type</p>
        <p class="mt-1 text-sm font-medium text-slate-900">{paper.venueType}</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Venue Level</p>
        <p class="mt-1 text-sm font-medium text-slate-900">{paper.venueLevel}</p>
      </div>
    </section>

    <img
      src={paperImage}
      alt={`${paper.title} teaser`}
      class="w-full rounded-md border border-slate-200 bg-white object-cover shadow-sm"
      loading="eager"
    />

    <section class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-950">Abstract</h2>
      <p class="max-w-4xl text-base leading-8 text-slate-700">{paper.abstract}</p>
    </section>

    {
      hasPaperUrl ? (
        <a
          href={paperUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex rounded-md bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800"
        >
          View Paper
        </a>
      ) : (
        <p class="inline-flex rounded-md border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600">
          Coming soon.
        </p>
      )
    }
  </article>
</BaseLayout>
