---
import Tag from './Tag.astro';
import AuthorList from './AuthorList.astro';

type Author =
  | string
  | {
      name: string;
      bold?: boolean;
      corresponding?: boolean;
    };

interface PaperData {
  slug: string;
  title: string;
  authors: Author[];
  venue: string;
  acceptedDate: string;
  fieldTags: string[];
  levelTags: string[];
  summary: string;
}

interface Props {
  paper: PaperData;
}

const { paper } = Astro.props;
const base = import.meta.env.BASE_URL;
const date = new Date(`${paper.acceptedDate}T00:00:00`);
const displayDate = date.toLocaleDateString('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<a
  href={`${base}papers/${paper.slug}/`}
  class="block rounded-md border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow-md"
>
  <article class="space-y-3">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <h3 class="text-lg font-semibold leading-snug text-slate-950">
        {paper.title}
      </h3>
      <time class="shrink-0 text-sm text-slate-500" datetime={paper.acceptedDate}>{displayDate}</time>
    </div>

    <AuthorList authors={paper.authors} class="text-sm leading-6 text-slate-700" />
    <p class="text-sm font-medium italic text-slate-800">{paper.venue}</p>
    <p class="text-sm leading-6 text-slate-600 underline decoration-slate-300 underline-offset-2">{paper.summary}</p>

    <div class="flex flex-wrap gap-2 pt-1">
      {paper.fieldTags.map((tag) => <Tag label={tag} type="field" />)}
      {paper.levelTags.map((tag) => <Tag label={tag} type="level" />)}
    </div>
  </article>
</a>
