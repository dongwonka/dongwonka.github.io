---
interface Props {
  label: string;
  type: 'field' | 'level';
}

const { label, type } = Astro.props;

const classes =
  type === 'field'
    ? 'border-sky-200 bg-sky-50 text-sky-800'
    : 'border-amber-200 bg-amber-50 text-amber-800';
---

<span class={`inline-flex items-center rounded-md border px-2.5 py-1 text-xs font-medium ${classes}`}>
  {label}
</span>
